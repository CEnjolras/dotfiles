# /usr/share/libalpm/hooks/clear_cache.hook

[Trigger]
Operation = Upgrade
Operation = Remove
Type = Package

# Uncomment this line if you also want to clear cache on installation
#Operation = Install

[Action]
Description = Clearing yay and pacman cache...
When = PreTransaction
Exec = /bin/sh -c 'yay -Scc --noconfirm && paccache -r'
